{
  "compilerOptions": {
    "target": "ES2017",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "lib": ["ES2017"],
    "types": ["node"],
    "noEmit": true,
    "ignoreDeprecations": "6.0"
  },
  "include": ["src"]
}